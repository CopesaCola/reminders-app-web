# Postgres connection string (local Docker, hosted, or Neon)
# Local Docker example: postgres://reminders:pass@localhost:5432/reminders
# Neon example: postgres://user:pass@host.neon.tech/db?sslmode=require
DATABASE_URL=postgres://user:password@host:5432/reminders

# Set to "loose" to skip cert verification, "require" for strict verification,
# or leave unset to disable SSL (default for local Postgres).
DATABASE_SSL=

# Password to access the app (any string you'll remember)
APP_PASSWORD=change-me

# 32+ char random secret for cookie session encryption
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-with-32-plus-char-random-string

# VAPID keys for Web Push (generate with `npm run vapid:gen`)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Required by Web Push spec — your contact email
VAPID_SUBJECT=mailto:you@example.com

# Bearer token cron must present in Authorization header to fire reminders
CRON_SECRET=replace-with-random-string

# IANA timezone for date math (e.g. America/New_York, Europe/London)
APP_TIMEZONE=America/New_York
