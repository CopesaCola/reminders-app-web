# docker-compose.yml uses these. Copy to .env (same dir as compose file) and edit.

# Where Unraid stores per-app data
APPDATA_DIR=/mnt/user/appdata/reminders

# Postgres
POSTGRES_USER=reminders
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=reminders

# App
APP_PASSWORD=pick-something-you-remember

# 32+ char hex; generate with:
#   docker run --rm node:20-alpine node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-with-32-plus-char-random-string

# VAPID keys; generate with:
#   docker run --rm -v "$PWD":/app -w /app node:20-alpine npm run vapid:gen
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Bearer token User Scripts uses when curl-ing the cron endpoints
CRON_SECRET=replace-with-random-string

# IANA timezone for date math (e.g. America/New_York, Europe/London)
APP_TIMEZONE=America/New_York

# Cloudflare Tunnel token (Zero Trust dashboard → Networks → Tunnels → Connector token)
CLOUDFLARE_TUNNEL_TOKEN=
